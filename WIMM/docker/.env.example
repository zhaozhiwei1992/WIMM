# WIMM docker-compose 环境变量
# 复制本文件为 .env 并填写实际值: cp .env.example .env

# ---------- 数据库 ----------
# 数据库密码(生产请改成强密码, 并与 application-prod.yml 保持一致)
DB_PASSWORD=wimm
# 库名/用户名, 一般不用改
DB_NAME=wimm
DB_USER=wimm

# ---------- AI 记账(必填) ----------
# OpenAI 兼容接口的 API Key, 未配置则应用正常启动, 仅 AI 记账接口报错
OPENAI_API_KEY=sk-替换为你的key
# 可选: OpenAI 兼容代理地址(默认官方)
# OPENAI_BASE_URL=https://api.openai.com

# ---------- JVM(可选) ----------
# 按 NAS 内存调整, 默认 512m 堆
# JAVA_OPTS=-Xmx512m

# ---------- jar 路径 ----------
# 后端 jar 所在的宿主机目录（jar 文件须命名为 app.jar）。
# docker-compose 会把 ${JAR_PATH}/app.jar 挂载进容器。
# 默认 . 即 docker/ 目录；可改成绝对路径，如 /opt/wimm
JAR_PATH=.
